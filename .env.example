# ============================================================
# AssetSpatial Backend — Environment Variables
# cp .env.example .env  then edit before running
# ============================================================

PORT=3001
NODE_ENV=development

# MongoDB — required. Install locally or use MongoDB Atlas free tier.
# Local:  mongodb://localhost:27017/assetspatial
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/assetspatial
MONGO_URI=mongodb://localhost:27017/assetspatial
MONGO_DB_NAME=assetspatial

# Redis — optional for local dev. If absent, rate limiting uses
# in-memory store and OCR/Excel queues process synchronously.
# Install: https://redis.io/docs/getting-started/installation/
REDIS_URL=redis://localhost:6379

# JWT — REQUIRED. Must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# GridFS bucket names (no need to change)
GRIDFS_BUCKET_PHOTOS=photos
GRIDFS_BUCKET_DOCUMENTS=documents
GRIDFS_BUCKET_EXCEL=excel

# File upload limits (MB)
MAX_PHOTO_SIZE_MB=15
MAX_PHOTOS_PER_ASSET=50
MAX_DOCUMENT_SIZE_MB=50
MAX_EXCEL_SIZE_MB=100

# OCR — Tesseract language packs
# Install: sudo apt install tesseract-ocr tesseract-ocr-yor tesseract-ocr-hau
# Windows: https://github.com/UB-Mannheim/tesseract/wiki
TESSERACT_LANG=eng+yor+hau
TESSERACT_WORKERS=2

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# CORS — set to wherever your frontend is served from
CLIENT_URL=http://localhost:5500

LOG_LEVEL=info

# Optional: override seed admin credentials (used by: npm run seed)
# SEED_ADMIN_EMAIL=admin@assetspatial.gov.ng
# SEED_ADMIN_PASS=ChangeMe123!
